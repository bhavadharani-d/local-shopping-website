{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "token": {
      "type": "integer"
    },
    "total": {
      "type": "decimal"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "Order Received",
        "Preparing",
        "Ready",
        "Delivered"
      ]
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    }
  }
}
